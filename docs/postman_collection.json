{
  "info": {
    "_postman_id": "8c4a17df-88c9-4b45-a7b6-c956b7c5b128",
    "name": "Stock LSTM Prediction API",
    "description": "Collection for authentication, local model artifact training on Render Free, status checks, prediction, and metrics. Run Get Access Token, then Train Model before using Predict Next Close.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('token', pm.response.json().access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{base_url}}/auth/token",
            "description": "Authenticates and saves the returned JWT as the collection variable `token`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "ML (Administrator)",
      "item": [
        {
          "name": "Train Model",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticker\": \"{{ticker}}\",\n  \"start_date\": \"{{start_date}}\",\n  \"lookback\": {{lookback}},\n  \"epochs\": {{epochs}}\n}"
            },
            "url": "{{base_url}}/ml/train",
            "description": "Downloads market data and trains synchronously, writing model.pth, scaler.pkl, and metadata.json locally. Requires the administrator user. On Render Free the files are lost after restart, sleep, or redeploy."
          },
          "response": []
        },
        {
          "name": "Get Active Model",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/ml/active",
            "description": "Returns whether the local model artifacts exist and, when they do, their ticker, timestamp, parameters, and metrics."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Status Checks",
      "item": [
        {
          "name": "Root Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/",
            "description": "General API status and active-model availability."
          },
          "response": []
        },
        {
          "name": "Deployment Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health",
            "description": "Health endpoint suitable for deployment checks."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Prediction",
      "item": [
        {
          "name": "Predict Next Close",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prices\": [170.1, 171.2, 172.5, 171.8, 170.9, 169.5, 168.2, 169.1, 170.3, 171.5, 172.1, 173.4, 174.6, 173.8, 172.9, 171.5, 170.2, 171.1, 172.3, 173.5, 174.1, 175.4, 176.6, 175.8, 174.9, 173.5, 172.2, 173.1, 174.3, 175.5, 176.1, 177.4, 178.6, 177.8, 176.9, 175.5, 174.2, 175.1, 176.3, 177.5, 178.1, 179.4, 180.6, 179.8, 178.9, 177.5, 176.2, 177.1, 178.3, 179.5, 180.1, 181.4, 182.6, 181.8, 180.9, 179.5, 178.2, 179.1, 180.3, 181.5]\n}"
            },
            "url": "{{base_url}}/predict",
            "description": "Requires a JWT and an active model. Send at least 60 historical closing prices ordered from oldest to newest."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Monitoring",
      "item": [
        {
          "name": "Prometheus Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/metrics",
            "description": "Exposes metrics in Prometheus format."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://api-132t.onrender.com",
      "type": "string"
    },
    {
      "key": "username",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "password",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "ticker",
      "value": "AAPL",
      "type": "string"
    },
    {
      "key": "start_date",
      "value": "2018-01-01",
      "type": "string"
    },
    {
      "key": "lookback",
      "value": "60",
      "type": "string"
    },
    {
      "key": "epochs",
      "value": "50",
      "type": "string"
    }
  ]
}